                /* Calculation for the KPI/metric - All Base Measure New are calculations of that KPI/metric */ 
                 VAR Absolute_GHG_Emmissions = [Absolute GHG emmisions (total actual GHG footprint) New]
                 VAR GHG_Baseline_2015 = [2015 GHG Baseline (tonnes) New]
                
