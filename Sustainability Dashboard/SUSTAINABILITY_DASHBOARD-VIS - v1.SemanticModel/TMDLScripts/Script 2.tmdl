        measure 'Waste intensity (kg per pet visit) New' = ```
                
                /* Calculation for the KPI/metric - All Base Measure New are calculations of that KPI/metric */ 
                VAR _TotalNonMedicalWaste = [Total non-medical waste New]
                VAR _PetVisits = [Pet Visits New]
                
                RETURN
                    IF(
                        ISBLANK(_TotalNonMedicalWaste) || ISBLANK(_PetVisits), 
                        BLANK(), 
                        DIVIDE([Total non-medical waste New], [Pet Visits New])
                    )
                ```
