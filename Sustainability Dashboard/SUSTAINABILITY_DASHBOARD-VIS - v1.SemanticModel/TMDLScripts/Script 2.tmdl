createOrReplace

    ref table Measures_table

        measure '% Advocate New' = ```
                
                /* Calculation for the KPI/metric - All Base Measure New are calculations of that KPI/metric */ 
                 VAR _Advocate = [Advocate New]
                 VAR _Volume_D4C = [Volume of packaging classified as D4C New]
                 VAR _Volume_Not_D4C = [Volume of packaging classified as NOT D4C New]
                
                RETURN
                IF(ISBLANK(_Advocate) || ISBLANK(_Volume_D4C) || ISBLANK(_Volume_Not_D4C), BLANK()
                    , DIVIDE(_Advocate, (_Volume_D4C + _Volume_Not_D4C)))
                ```
            displayFolder: Scorecard Digital\Base Measure New

            annotation PBI_FormatHint = {"isGeneralNumber":true}

        measure '% Circular New' = ```
                
                  /* Calculation for the KPI/metric - All Base Measure New are calculations of that KPI/metric */ 
                  VAR _Circular = [Circular New]
                  VAR Volume_D4C = [Volume of packaging classified as D4C New]
                  VAR Volume_Not_D4C = [Volume of packaging classified as NOT D4C New]
                
                  RETURN
                  IF(ISBLANK(_Circular) || ISBLANK(Volume_D4C) || ISBLANK(Volume_Not_D4C), BLANK()
                    , DIVIDE(_Circular, (Volume_D4C + Volume_Not_D4C)) )
                ```
            displayFolder: Scorecard Digital\Base Measure New

            annotation PBI_FormatHint = {"isGeneralNumber":true}

        measure '% D4C New' = ```
                
                /* Calculation for the KPI/metric - All Base Measure New are calculations of that KPI/metric */ 
                VAR Volume_D4C = [Volume of packaging classified as D4C New]
                VAR Volume_Not_D4C = [Volume of packaging classified as NOT D4C New]
                
                RETURN
                IF(ISBLANK(Volume_D4C) || ISBLANK(Volume_Not_D4C), BLANK()
                    , DIVIDE(Volume_D4C, (Volume_D4C + Volume_Not_D4C)))
                
                ```
            displayFolder: Scorecard Digital\Base Measure New

            annotation PBI_FormatHint = {"isGeneralNumber":true}

        measure '% Eliminate New' = ```
                
                /* Calculation for the KPI/metric - All Base Measure New are calculations of that KPI/metric */ 
                 VAR _Eliminate = [Eliminate New] 
                 VAR _Volume_D4C = [Volume of packaging classified as D4C New]
                 VAR _Volume_Not_D4C = [Volume of packaging classified as NOT D4C New]
                
                 RETURN
                
                 IF(ISBLANK(_Eliminate) ||ISBLANK(_Volume_D4C) || ISBLANK(_Volume_Not_D4C), BLANK()
                
                    , DIVIDE(_Eliminate, (_Volume_D4C + _Volume_Not_D4C)))
                ```
            displayFolder: Scorecard Digital\Base Measure New

            annotation PBI_FormatHint = {"isGeneralNumber":true}

        measure '% recycled content New' = ```
                
                /* Calculation for the KPI/metric - All Base Measure New are calculations of that KPI/metric */ 
                VAR _Recycled_Content_Volume = [Recycled content volume New]
                VAR _Total_Plastic_Volume = [Total plastic volume (virgin + recycled) New]
                
                RETURN
                
                IF(ISBLANK(_Recycled_Content_Volume) || ISBLANK(_Total_Plastic_Volume), BLANK()
                    , DIVIDE(_Recycled_Content_Volume, _Total_Plastic_Volume))
                ```
            displayFolder: Scorecard Digital\Base Measure New

            annotation PBI_FormatHint = {"isGeneralNumber":true}

        measure '% virgin plastic change vs 2019 New' = ```
                
                /* Calculation for the KPI/metric - All Base Measure New are calculations of that KPI/metric */ 
                 VAR _Total_Plastic_Volume = [Total plastic volume (virgin + recycled) New]
                 VAR _Recycled_Content_Volume = [Recycled content volume New]
                 VAR _2019_Baseline = [2019 Virgin Plastic baseline (Plastic Only tonnes) New]
                 
                 RETURN
                 IF(ISBLANK(_Total_Plastic_Volume) || ISBLANK(_Recycled_Content_Volume) || ISBLANK(_2019_Baseline), BLANK()
                 , (DIVIDE((_Total_Plastic_Volume - _Recycled_Content_Volume), _2019_Baseline) - 1))
                ```
            displayFolder: Scorecard Digital\Base Measure New

            annotation PBI_FormatHint = {"isGeneralNumber":true}

        measure '2015 GHG Baseline (tonnes) New' = ```
                
                /* Calculation for the KPI/metric - All Base Measure New are calculations of that KPI/metric */ 
