model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-GB
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

/// Errors in queries that were loaded on 27/08/2025 14:06:30.
queryGroup 'Query Errors - 27/08/2025 14:06:30'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Dimension Tables'

	annotation PBI_QueryGroupOrder = 3

queryGroup 'Fact Tables'

	annotation PBI_QueryGroupOrder = 4

queryGroup Sources

	annotation PBI_QueryGroupOrder = 5

queryGroup 'Climate Queries'

	annotation PBI_QueryGroupOrder = 1

queryGroup 'Circularity Queries'

	annotation PBI_QueryGroupOrder = 2

queryGroup 'Climate Queries\Projects View Queries'

	annotation PBI_QueryGroupOrder = 0

/// Contains Historical Data
queryGroup 'CAP Projects History'

	annotation PBI_QueryGroupOrder = 7

/// New Data source for the KPI's
queryGroup 'New KPI''s'

	annotation PBI_QueryGroupOrder = 8

annotation __PBI_TimeIntelligenceEnabled = 0

