expression 'CAP Projects GHG Actual History' =
		let
		    Source = #"CAP YTD Data",
		
		    #"Remove projects not yet started" =
		        Table.SelectRows(Source, each [Start year] <= [Input Year]),
		
		    #"Group YTD Data Rows to get YTD" =
		        Table.Group(
		            #"Remove projects not yet started",
		            {"Timestamp", "Input Year", "Input Quarter", "Division","Unit / Region", "OE name", "#", "Activity Name", "Activity owner", "Activity Status"},
		            {{"Value", each List.Sum([GHG YTD]), type nullable number}}
		        ),
		
		    #"Create Attribute Column" =
		        Table.AddColumn(#"Group YTD Data Rows to get YTD", "Attribute", each "Actual", type text),
		
		    #"Rename Columns" =
		        Table.RenameColumns(
		            #"Create Attribute Column",
		            {
		                {"#", "Project"},
		                {"Input Year", "Year"},
		                {"Input Quarter", "Quarter"}
		            }
		        ),
		
		    #"Changed Type" =
		        Table.TransformColumnTypes(#"Rename Columns",{{"Quarter", Int64.Type}}),
		
		    #"Added KPI ID" =
		        Table.AddColumn(#"Changed Type", "KPI ID", each 28, Int32.Type),
		
		    #"Added Topic ID" =
		        Table.AddColumn(#"Added KPI ID", "Topic ID", each 1, Int64.Type)
		in
		    #"Added Topic ID"
