	annotation PBI_ResultType = Exception

expression TransformKpiData = ```
		(SourceTable as table, DivisionName as text) =>
		let
		    // 1. Rename columns safely (Using Table.ColumnNames to check existence)
		    ColNames = Table.ColumnNames(SourceTable),
		    RenameList = {{"KPIs", "Attributes"}, {"Category", "Topic"}},
		    Renamed = Table.RenameColumns(SourceTable, List.Select(RenameList, each List.Contains(ColNames, _{0})), MissingField.Ignore),
		    
		    // 2. Replace Errors globally before unpivoting
		    ReplaceErrors = Table.ReplaceErrorValues(Renamed, List.Transform(Table.ColumnNames(Renamed), each {_, null})),
		    
		    // 3. Transformation logic
		    AllCols = Table.ColumnNames(ReplaceErrors),
		    GetCols = (prefix) => List.Select(AllCols, each Text.StartsWith(_, prefix, Comparer.OrdinalIgnoreCase)),
		    
		    // Updated Unpivot: Force the 'Value' column to be a number IMMEDIATELY
		    UnpivotCategory = (tbl, cols, tag) => 
		        let 
		            u = Table.Unpivot(tbl, cols, "Period", "Value"),
		            Typed = Table.TransformColumnTypes(u, {{"Value", type number}}) 
		        in Table.AddColumn(Typed, "Attribute", each tag),
		    
		    Combined = Table.Combine({
		        UnpivotCategory(ReplaceErrors, GetCols("Target"), "Target"),
		        UnpivotCategory(ReplaceErrors, GetCols("Actual"), "Actual"),
		        UnpivotCategory(ReplaceErrors, GetCols("YEE"), "YEE"),
		        UnpivotCategory(ReplaceErrors, GetCols("Replan"), "Replan"),
		        UnpivotCategory(ReplaceErrors, GetCols("Investment YTD"), "Investment YTD"),
		        UnpivotCategory(ReplaceErrors, GetCols("Investment YEE"), "Investment YEE"),
		        UnpivotCategory(ReplaceErrors, GetCols("planned"), "Planned Activities")
		    }),
		    
		    //Get the list of column names
		    AllColumnNames = Table.ColumnNames(Combined),
		    
		    //Select the names to keep
		    ColumnsToKeep = List.Select(AllColumnNames, each 
		        not Text.Contains(_, "Target", Comparer.OrdinalIgnoreCase) and
		        not Text.Contains(_, "Target", Comparer.OrdinalIgnoreCase) and
		        not Text.Contains(_, "Actual", Comparer.OrdinalIgnoreCase) and
		        not Text.Contains(_, "Replan", Comparer.OrdinalIgnoreCase) and
		        not Text.Contains(_, "Planned", Comparer.OrdinalIgnoreCase) and
		        not Text.Contains(_, "YEE", Comparer.OrdinalIgnoreCase) and
		        not Text.Contains(_, "YTD", Comparer.OrdinalIgnoreCase)
		    ),
		
		    //Apply the selection
		
		    FilteredTable = Table.SelectColumns(Combined, ColumnsToKeep),
		
		
		    // 4. Add Year and Quarter
		    AddYear = Table.AddColumn(FilteredTable, "Year", each 
		        let d = Text.PositionOfAny([Period], {"0".."9"}) 
		        in if d >= 0 then Number.FromText(Text.Middle([Period], d, 4)) else null, Int64.Type),
		    
		    AddQuarter = Table.AddColumn(AddYear, "Quarter", each 
		        if [Attribute] = "Actual" or [Attribute] = "Target" then "Q4"
		        else if [Attribute] = "Replan" then "Q3"
		        else if [Attribute] = "Planned Activities" then "Q4"
		        else if Text.Contains([Period],"Q1") then "Q1" else if Text.Contains([Period],"Q2") then "Q2" 
		        else if Text.Contains([Period],"Q3") then "Q3" else if Text.Contains([Period],"Q4") then "Q4" else null),
		
		    AddDiv = Table.AddColumn(AddQuarter, "Division", each DivisionName)
		in
		    AddDiv
		```
