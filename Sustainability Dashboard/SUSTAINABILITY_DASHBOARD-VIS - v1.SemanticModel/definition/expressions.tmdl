expression 'CAP YTD Projects GHG Scopes' = ```
		let
		    Source = #"CAP Data",
		    #"Removed Unwanted Columns" = Table.RemoveColumns(Source,{"Input Version", "Auto-generated number", "Activity Description", "Activity owner", "Existing in CAP", "Activity Status", "Level of Confidence", "GHG YTD", "GHG 2024 no growth & discounted (tCO2e)", "GHG 2025 no growth & discounted (tCO2e)", "GHG 2026 no growth & discounted (tCO2e)", "GHG 2027 no growth & discounted (tCO2e)", "GHG 2028 no growth & discounted (tCO2e)", "GHG 2029 no growth & discounted (tCO2e)", "GHG 2030 no growth & discounted (tCO2e)", "COGS YTD", "COGS 2024", "COGS 2025", "COGS 2026", "COGS 2027", "COGS 2028", "COGS 2029", "COGS 2030", "SWB YTD", "SWB 2024", "SWB 2025", "SWB 2026", "SWB 2027", "SWB 2028", "SWB 2029", "SWB 2030", "EXPENSES YTD", "EXPENSES 2024", "EXPENSES 2025", "EXPENSES 2026", "EXPENSES 2027", "EXPENSES 2028", "EXPENSES 2029", "EXPENSES 2030", "CAPEX YTD", "CAPEX 2024", "CAPEX 2025", "CAPEX 2026", "CAPEX 2027", "CAPEX 2028", "CAPEX 2029", "CAPEX 2030", "discount1", "discount2", "discount3", "AEP status", "Unit / Region", "OE name", "Activity Name", "Pillar", "Type of activity"}),
		    #"Filtered Rows" = Table.SelectRows(#"Removed Unwanted Columns", each [Input Year] <= [End Year] and [Input Year] >= [Start year] and [GHG Scope] <> 0),
		    #"Duplicated Column" = Table.DuplicateColumn(#"Filtered Rows", "Division", "Division - Copy"),
		    #"Reordered Columns" = Table.ReorderColumns(#"Duplicated Column",{"Timestamp", "Input Year", "Input Quarter", "Division", "#", "Division - Copy", "Start year", "End Year", "GHG Scope"}),
		    //#"Merged Columns" = Table.CombineColumns(#"Reordered Columns",{"#", "Division - Copy", "Unit / Region", "OE name", "Activity Name", "Pillar", "Type of activity"},Combiner.CombineTextByDelimiter("-", QuoteStyle.None),"Project Id"),
		    #"Merged Columns" = Table.CombineColumns(#"Reordered Columns",{"#", "Division - Copy"},Combiner.CombineTextByDelimiter("-", QuoteStyle.None),"Project Id"),
		    #"Grouped Rows" = Table.Group(#"Merged Columns", {"Timestamp", "Input Year", "Input Quarter", "Division", "GHG Scope"}, {{"Value", each List.Count(List.Distinct([Project Id])), type nullable number}}),
		    #"Add End of Quarter" = Table.AddColumn(
		            #"Grouped Rows", 
		            "End_Of_Quarter_Date", 
		            each let
		                parts = Text.Split([Timestamp], "-Q"),
		                year = Number.FromText(parts{0}),
		                quarter = Number.FromText(parts{1}),
		                lastMonth = quarter * 3,
		                lastDay = Date.EndOfMonth(#date(year, lastMonth, 1))
		            in
		                lastDay
		        ),
		    #"Changed Type" = Table.TransformColumnTypes(#"Add End of Quarter",{{"End_Of_Quarter_Date", type date}}),
		    #"Renamed Columns" = Table.RenameColumns(#"Changed Type",{{"Input Year", "Year"}, {"Input Quarter", "Quarter"}}),
		    //TODO: If adding OE to the report visuals and filters, add OEhere as well
		    // Sort by Date to ensure correct cumulative order
		    #"SortedRows" = Table.Sort(#"Renamed Columns", {{"Division", Order.Ascending}, {"End_Of_Quarter_Date", Order.Ascending}, {"GHG Scope", Order.Ascending}}),
		
		    // Group by Year to calculate YTD within each year
		    #"GroupedByYear" = Table.Group(
		        #"SortedRows",
		        //TODO: Add OE
		        {"Division", "Year", "GHG Scope"},
		        {
		            {"Data", (t) =>
		                let
		                    // Sort inside each year
		                    // Sorted = Table.Sort(t, {{"End_Of_Quarter_Date", Order.Ascending}}),
		                    // Add Index for cumulative sum
		                    Indexed = Table.AddIndexColumn(t, "Index", 1, 1, Int64.Type),
		                    // Add YTD column using List.Range cumulative sum
		                    AddYTD = Table.AddColumn(
		                        Indexed,
		                        "YTD",
		                        (row) => List.Sum(List.FirstN(Indexed[Value], row[Index]))
		                    ),
		                    // Remove helper column
		                    RemovedIndex = Table.RemoveColumns(AddYTD, {"Index"})
		                in
		                    RemovedIndex
		            , type table [Timestamp=text, Division=text, End_Of_Quarter_Date=date, Value=number, Year=number, Quarter=number, YTD=number]}
		        }
		    ),
		
		    // Expand back to flat table
		    #"Expanded" = Table.ExpandTableColumn(#"GroupedByYear", "Data", {"Timestamp", "End_Of_Quarter_Date", "Value", "Quarter", "YTD"}),
		    #"Create Attribute ID column" = Table.AddColumn(#"Expanded", "Attribute ID", each if [GHG Scope] = 1 then 22 else if [GHG Scope] = 2 then 24 else if [GHG Scope] = 3 then 26 else null, type number),
		    #"Merged Queries" = Table.NestedJoin(#"Create Attribute ID column", {"Attribute ID"}, #"Topics and KPIs", {"KPI ID"}, "Topics and KPIs", JoinKind.LeftOuter),
		    #"Expanded Topics and KPIs" = Table.ExpandTableColumn(#"Merged Queries", "Topics and KPIs", {"Topic ID"}, {"Topic ID"}),
		    #"Division ID - Match Division to Division Table" = Table.NestedJoin(#"Expanded Topics and KPIs", {"Division"}, #"Dim Division", {"Division"}, "Division.1", JoinKind.LeftOuter),
		    #"Get Division ID" = Table.ExpandTableColumn(#"Division ID - Match Division to Division Table", "Division.1", {"Division ID"}, {"Division ID"}),
		    #"Added Attribute column" = Table.AddColumn(#"Get Division ID", "Attribute", each "YTD Active Projects", type text),
		    #"Added Standard Quarter column" = Table.AddColumn(#"Added Attribute column", "Standard Quarter", each null),
