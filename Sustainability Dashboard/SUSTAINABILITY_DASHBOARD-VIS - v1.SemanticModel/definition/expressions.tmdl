expression 'Petcare KPI Values' = ```
		let
		    Source = SharePoint.Files(#"Sharepoint File Path", [ApiVersion = 15]),
		    #"File_Name_Folder_Path" = Source{[Name="Digital Scorecard Data Fields.xlsx",#"Folder Path"=Folder_Path]}[Content],
		    #"Imported Excel Workbook" = Excel.Workbook(#"File_Name_Folder_Path"),
		    #"Petcare KPI Values_Sheet" = #"Imported Excel Workbook"{[Item="Petcare KPI Values",Kind="Sheet"]}[Data],
		    #"Promoted Headers" = Table.PromoteHeaders(#"Petcare KPI Values_Sheet", [PromoteAllScalars=true]),
		    #"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers",{{"Category", type text}, {"KPIs", type text}, {"UOM", type text}, {"Target 2025", type any}, {"Target 2026", Int64.Type}, {"Target 2027", type any}, {"Target 2028", type any}, {"Target 2029", type any}, {"Target 2030", type text}, {"Actual 2023", type number}, {"Actual 2024", type any}, {"Actual 2025", type any}, {"YEE 2023 Q1", type any}, {"YEE 2023 Q2", Int64.Type}, {"YEE 2023 Q3", type number}, {"YEE 2023 Q4", type number}, {"YEE 2024 Q1", type any}, {"YEE 2024 Q2", type any}, {"YEE 2024 Q3", type any}, {"YEE 2024 Q4", type any}, {"YEE 2025 Q1", type any}, {"YEE 2025 Q2", type any}, {"YEE 2025 Q3", type any}, {"YEE 2025 Q4", type any}, {"Replan $ 2023", type any}, {"Replan $ 2024", type number}, {"Replan $ 2025", type number}, {"Investment YTD 2023 Q3", type number}, {"Investment YTD 2023 Q4", Int64.Type}, {"Investment YTD 2024 Q1", type any}, {"Investment YTD 2024 Q2", type number}, {"Investment YTD 2024 Q3", type number}, {"Investment YTD 2024 Q4", type number}, {"Investment YTD 2025 Q1", Int64.Type}, {"Investment YTD 2025 Q2", type number}, {"Investment YTD 2025 Q3", type number}, {"Investment YTD 2025 Q4", type number}, {"Investment YEE 2023 Q1", type any}, {"Investment YEE 2023 Q2", type any}, {"Investment YEE 2023 Q3", type number}, {"Investment YEE 2023 Q4", type number}, {"Investment YEE 2024 Q1", type any}, {"Investment YEE 2024 Q2", type any}, {"Investment YEE 2024 Q3", type number}, {"Investment YEE 2024 Q4", type number}, {"Investment YEE 2025 Q1", type number}, {"Investment YEE 2025 Q2", type number}, {"Investment YEE 2025 Q3", type number}, {"Investment YEE 2025 Q4", type number}, {"planned # of activities 2023", type any}, {"planned # of activities 2024", type any}, {"planned # of activities 2025", type any}}),
		
		    //Rename the columns
		    Renamed = Table.RenameColumns(#"Changed Type", {{"KPIs","Attributes"},{"Category","Topic"}}, MissingField.Ignore),
		
		    // This creates a list of all columns and tells Power Query to replace errors in all of them with null
		    ReplaceErrors = Table.ReplaceErrorValues(Renamed, List.Transform(Table.ColumnNames(Renamed), each {_, null})),
		
		    //find groups of columns by prefix (using OrdinalIgnoreCase to be safe)
		    AllCols = Table.ColumnNames(ReplaceErrors),
		    TargetCols = List.Select(AllCols, each Text.StartsWith(_, "Target", Comparer.OrdinalIgnoreCase)),
		    ActualCols = List.Select(AllCols, each Text.StartsWith(_, "Actual", Comparer.OrdinalIgnoreCase)),
		    YEECols = List.Select(AllCols, each Text.StartsWith(_, "YEE", Comparer.OrdinalIgnoreCase)),
		    ReplanCols = List.Select(AllCols, each Text.StartsWith(_, "Replan", Comparer.OrdinalIgnoreCase)),
		    InvestYTDCols = List.Select(AllCols, each Text.StartsWith(_, "Investment YTD", Comparer.OrdinalIgnoreCase)),
		    InvestYEECols = List.Select(AllCols, each Text.StartsWith(_, "Investment YEE", Comparer.OrdinalIgnoreCase)),
		    PlannedCols = List.Select(AllCols, each Text.StartsWith(_, "planned", Comparer.OrdinalIgnoreCase)),
		
		    //helper to unpivot a category and tag it
		
		    UnpivotCategory = (tbl as table, cols as list, tag as text) =>
		    if List.Count(cols)=0 then #table({}, {}) else
		    let u = Table.Unpivot(tbl, cols, "Period", "Value") in Table.AddColumn(u, "Attribute", each tag),
		
		    //unpivot each logical block
		    U_Target = UnpivotCategory(ReplaceErrors, TargetCols, "Target"),
		    U_Actual = UnpivotCategory(ReplaceErrors, ActualCols, "Actual"),
		    U_YEE = UnpivotCategory(ReplaceErrors, YEECols, "YEE"),
		    U_Replan = UnpivotCategory(ReplaceErrors, ReplanCols, "Replan"),
		    U_InvYTD = UnpivotCategory(ReplaceErrors, InvestYTDCols, "Investment YTD"),
		    U_InvYEE = UnpivotCategory(ReplaceErrors, InvestYEECols, "Investment YEE"),
		    U_Planned = UnpivotCategory(ReplaceErrors, PlannedCols, "Planned Activities"),
		
		    //combine all unpivoted sets
		    ToCombine = List.Select({U_Target,U_Actual,U_YEE,U_Replan,U_InvYTD,U_InvYEE,U_Planned}, each _ <> null and Table.RowCount(_) > 0),
		    Combined = if List.Count(ToCombine)=0 then #table({}, {}) else Table.Combine(ToCombine),
		
		    //Get the list of column names
		    AllColumnNames = Table.ColumnNames(Combined),
		    
		    //Select the names to keep
		    ColumnsToKeep = List.Select(AllColumnNames, each 
		        not Text.Contains(_, "Target", Comparer.OrdinalIgnoreCase) and
		        not Text.Contains(_, "Target", Comparer.OrdinalIgnoreCase) and
		        not Text.Contains(_, "Actual", Comparer.OrdinalIgnoreCase) and
		        not Text.Contains(_, "Replan", Comparer.OrdinalIgnoreCase) and
		        not Text.Contains(_, "Planned", Comparer.OrdinalIgnoreCase) and
		        not Text.Contains(_, "YEE", Comparer.OrdinalIgnoreCase) and
		        not Text.Contains(_, "YTD", Comparer.OrdinalIgnoreCase)
		    ),
		
		    //Apply the selection
		
		    FilteredTable = Table.SelectColumns(Combined, ColumnsToKeep),
		
		    //extract Year and Quarter from the column name in Period
		
		    AddYear = Table.AddColumn(FilteredTable, "Year", each 
		        let
		            // 1. Find the index (position) of the first number in the string
		            FirstDigitPos = Text.PositionOfAny([Period], {"0".."9"}),
		            // 2. Extract 4 characters starting from that position
		            YearText = if FirstDigitPos >= 0 then Text.Middle([Period], FirstDigitPos, 4) else null
		        in
		            try Number.FromText(YearText) otherwise null, 
		        Int64.Type
		    ),
		    AddQuarter = Table.AddColumn(AddYear, "Quarter", each 
		    if [Attribute] = "Actual" or [Attribute] = "Target" then "Q4"
		    else if [Attribute] = "Replan" then "Q3"
		    else if [Attribute] = "Planned Activities" then "Q4"
		    else if Text.Contains([Period],"Q1") then "Q1" 
		    else if Text.Contains([Period],"Q2") then "Q2" 
		    else if Text.Contains([Period],"Q3") then "Q3" 
		    else if Text.Contains([Period],"Q4") then "Q4" 
		    else null
		),
		
		    //build End Of Quarter Date
		    QuarterMonth = Table.AddColumn(AddQuarter, "QuarterEndMonth", each if [Quarter]="Q1" then 3 else if [Quarter]="Q2" then 6 else if [Quarter]="Q3" then 9 else if [Quarter]="Q4" then 12 else 12, Int64.Type),
		    EndOfQuarter = Table.AddColumn(QuarterMonth, "End Of Quarter Date",
		    each if [Year] <> null then Date.From(#date([Year], [QuarterEndMonth], if [QuarterEndMonth] = 3 then 31 else if [QuarterEndMonth] = 6 then 30 else if [QuarterEndMonth] = 9 then 30 else 31)) else null, type date),
		    AddTimestamp = Table.AddColumn(EndOfQuarter, "Timestamp", each if [Quarter] <> null then Text.From([Year]) & "-Q" & Text.Middle([Quarter],1,1) else if [Year] <> null then Text.From([Year]) else null, type text),
		    AddTimestampKPI = Table.AddColumn(AddTimestamp, "Timestamp - KPI Trends", each if [Timestamp] <> null then [Timestamp] else null, type text),
		
		    //standardize Attribute name
		    NormAttribute = Table.TransformColumns(AddTimestampKPI, {{"Attribute", each Text.Trim(Text.From(_)), type text}}),
		
		    //Change Value types and final column mapping
		    ChangedTypes = Table.TransformColumnTypes(NormAttribute, {{"Value", type number}, {"Year", Int64.Type}}, "en-US"),
		    
		    #"Merge for Topic and Attribute IDs" = Table.NestedJoin(ChangedTypes, {"Attributes"}, #"Topics and KPIs", {"KPI Name "}, "Topics and KPIs", JoinKind.LeftOuter),
		    #"Expanded Topics and KPIs" = Table.ExpandTableColumn(#"Merge for Topic and Attribute IDs", "Topics and KPIs", {"KPI ID", "Topic ID"}, {"Attribute ID", "Topic ID"}),
		    #"Changed Type1" = Table.TransformColumnTypes(#"Expanded Topics and KPIs",{{"Attribute ID", Int64.Type}}),
		    #"Merged Report Type" = Table.FuzzyNestedJoin(#"Changed Type1", {"Attribute"}, #"Dim Report Type", {"Report Type"}, "Report Type", JoinKind.LeftOuter, [IgnoreCase=true, IgnoreSpace=true]),
		    #"Expand Report Type" = Table.ExpandTableColumn(#"Merged Report Type", "Report Type", {"Report Type ID"}, {"Report Type ID"}),
		    // Safety check for final column selection
		    AvailableCols = Table.ColumnNames(#"Expand Report Type"),
		    RequiredCols = {"Timestamp","Division ID","Topic ID","UOM","Topic","Attribute ID","Attributes","Year","End Of Quarter Date","Attribute","Value","Report Type ID","Quarter","Timestamp - KPI Trends","OE","Division","Attribute"},
		    IntersectCols = List.Intersect({AvailableCols, RequiredCols}),
		    Final = Table.SelectColumns(#"Expand Report Type", IntersectCols)
		in
		    Final
