expression 'GHG Activity Set Scopes - YTD' = ```
		let
		    Source = #"CAP YTD Data",
		    #"Group YTD Data Rows to get YTD" = Table.Group(Source, {"Timestamp", "Input Year", "Division", "OE name", "GHG Scope"}, {{"YTD", each List.Sum([GHG YTD]), type nullable number}}),
		    #"Remove Rows where Scope is 0 or null" = Table.SelectRows(#"Group YTD Data Rows to get YTD", each ([GHG Scope] <> null and [GHG Scope] <> 0)),
		    #"Create Attribute ID column" = Table.AddColumn(#"Remove Rows where Scope is 0 or null", "Attribute ID", each if [GHG Scope] = 1 then 22 else if [GHG Scope] = 2 then 24 else if [GHG Scope] = 3 then 26 else null, type number),
		    #"Merged Queries" = Table.NestedJoin(#"Create Attribute ID column", {"Attribute ID"}, #"Topics and KPIs", {"KPI ID"}, "Topics and KPIs", JoinKind.LeftOuter),
		    #"Expanded Topics and KPIs" = Table.ExpandTableColumn(#"Merged Queries", "Topics and KPIs", {"Topic ID"}, {"Topic ID"}),
		    #"Division ID - Match Division to Division Table" = Table.NestedJoin(#"Expanded Topics and KPIs", {"Division"}, #"Dim Division", {"Division"}, "Division.1", JoinKind.LeftOuter),
		    #"Get Division ID" = Table.ExpandTableColumn(#"Division ID - Match Division to Division Table", "Division.1", {"Division ID"}, {"Division ID"}),
		    #"Added Attribute column" = Table.AddColumn(#"Get Division ID", "Attribute", each "YTD", type text),
		    #"Added Standard Quarter column" = Table.AddColumn(#"Added Attribute column", "Standard Quarter", each null),
		    #"Add Timestamp - KPI Trends column" = Table.DuplicateColumn(#"Added Standard Quarter column", "Timestamp", "Timestamp - Copy"),
		    #"Renamed columns" = Table.RenameColumns(#"Add Timestamp - KPI Trends column",{{"Input Year", "Year"}, {"YTD", "Value"}, {"Timestamp - Copy", "Timestamp - KPI Trends"}, {"OE name", "OE"}}),
		    #"Report Type ID - Match Attribute with Fact Table" = Table.NestedJoin(#"Renamed columns", {"Attribute"}, #"Dim Report Type", {"Report Type"}, "Report Type", JoinKind.LeftOuter),
		    #"Get Report Type ID" = Table.ExpandTableColumn(#"Report Type ID - Match Attribute with Fact Table", "Report Type", {"Report Type ID"}, {"Report Type ID"}),
		    #"Add End of Quarter Date" = 
		        Table.AddColumn(
		            #"Get Report Type ID", 
		            "End Of Quarter Date", 
		            each let
		                parts = Text.Split([Timestamp], "-Q"),
		                year = Number.FromText(parts{0}),
		                quarter = Number.FromText(parts{1}),
		                lastMonth = quarter * 3,
		                lastDay = Date.EndOfMonth(#date(year, lastMonth, 1))
		            in
		                lastDay
		        ),
		    #"Changed Data Type of Columns to Match with Fact Table" = Table.TransformColumnTypes(#"Add End of Quarter Date",{{"Standard Quarter", type text}, {"Attribute", type text}, {"Attribute ID", Int64.Type}, {"End Of Quarter Date", type date}}),
		    #"Removed Columns" = Table.RemoveColumns(#"Changed Data Type of Columns to Match with Fact Table",{"Division", "GHG Scope"})
		in
		    #"Removed Columns"
		```
	lineageTag: bf523162-1b56-46a0-9759-c12039fb7ac1
	queryGroup: 'Climate Queries'

