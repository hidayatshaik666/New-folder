expression 'Circularity YTD' = ```
		let
		    Source = #"Circularity Source",
		    #"Add Report Type ID" = Table.AddColumn(Source, "Report Type ID", each 10, Int64.Type),
		    #"Renamed Columns" = Table.RenameColumns(#"Add Report Type ID",{{"Value", "Qtr Value"}}),
		    SortedRows = Table.Sort(#"Renamed Columns", {{"OE", Order.Ascending},{"Division ID", Order.Ascending},{"Attribute ID", Order.Ascending},{"Year", Order.Ascending}, {"End Of Quarter Date", Order.Ascending}}),
		    AddedIndex = Table.AddIndexColumn(SortedRows, "Index", 0, 1, Int64.Type),
		    AddedRunningSum = Table.AddColumn(AddedIndex, "Value", each 
		        let
		            currentOE = _[OE],
		            currentDivision = _[Division ID],
		            currentAttribute = _[Attribute ID],
		            currentYear = _[Year],
		            currentIndex = _[Index],
		            filteredRows = Table.SelectRows(AddedIndex, (r) => 
		                r[OE] = currentOE and 
		                r[Division ID] = currentDivision and 
		                r[Attribute ID] = currentAttribute and 
		                r[Year] = currentYear and 
		                r[Index] <= currentIndex
		            )
		        in
		            List.Sum(filteredRows[Qtr Value])
		    , type number),
		    RemovedIndex = Table.RemoveColumns(AddedRunningSum,{"Index"}),
		    #"Removed Other Columns" = Table.SelectColumns(RemovedIndex,{"OE", "Year", "End Of Quarter Date", "Attribute ID", "Topic ID", "Division ID", "Report Type ID", "Value"}),
		    #"Add Attribute" = Table.AddColumn(#"Removed Other Columns", "Attribute", each "YTD"),
		  #"Add Timestamp" = Table.AddColumn(#"Add Attribute", "Timestamp", each Text.Combine({Text.From(Date.Year([End Of Quarter Date])),"-Q" ,Text.From(Date.Month([End Of Quarter Date])/3)}), type text),
		    #"Changed Type" = Table.TransformColumnTypes(#"Add Timestamp",{{"Attribute", type text}})
		in
		    #"Changed Type"
		```
