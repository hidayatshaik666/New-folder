expression 'CAP Projects GHG Planned History' =
		let
		    Source = #"CAP YEE Data",
		
		    #"RemainingColumns" = Table.ColumnNames(Source),
		    Digits = {"0".."9"},
		
		    #"ColumnsToAggregate" =
		        List.Select(
		            #"RemainingColumns",
		            each Text.PositionOfAny(_, Digits) <> -1
		        ),
		
		    #"ColumnsToGroup" =
		        {
		            "Timestamp", "Input Year", "Input Quarter",
		            "Division", "Unit / Region", "OE name",
		            "#", "Activity Name", "Activity owner", "Activity Status"
		        },
		
		    #"Aggregations" =
		        List.Transform(
		            #"ColumnsToAggregate",
		            (col) =>
		                { col, each List.Sum(List.Transform(_, (r) => Record.Field(r, col))), type number }
		        ),
		
		    #"GroupedTable" =
		        Table.Group(Source, #"ColumnsToGroup", #"Aggregations"),
		
		    #"Unpivoted Years" =
		        Table.Unpivot(#"GroupedTable", #"ColumnsToAggregate", "Year", "Value"),
		
		    #"Changed Type" =
		        Table.TransformColumnTypes(#"Unpivoted Years",{{"Year", Int64.Type}}),
		    #"Get the Last year data" = Table.SelectRows(#"Changed Type", each [Input Year]=(List.Max(#"Changed Type"[Input Year], each _)-1)),
		
		    // Forward-looking Planned logic
		    #"Filter Next Year" =
		        Table.SelectRows(#"Get the Last year data", each [Year] = [Input Year] + 1),
		
		    #"Create Attribute Column" =
		        Table.AddColumn(#"Filter Next Year", "Attribute", each "Planned", type text),
		
		    #"Rename Columns" =
		        Table.RenameColumns(
		            #"Create Attribute Column",
		            {
		                {"#", "Project"},
		                {"Input Quarter", "Quarter"}
		            }
		        ),
		
		    // Remove snapshot metadata
		    #"Removed Columns" =
		        Table.RemoveColumns(#"Rename Columns",{"Input Year"}),
		
		    #"Reordered Columns" =
		        Table.ReorderColumns(
		            #"Removed Columns",
		            {
		                "Timestamp", "Year", "Quarter",
		                "Division", "OE name",
		                "Project", "Activity Name",
		                "Value", "Attribute"
		            }
		        ),
		
		    #"Changed Type1" =
		        Table.TransformColumnTypes(#"Reordered Columns",{{"Quarter", Int64.Type}}),
		
		    #"Added KPI ID" =
		        Table.AddColumn(#"Changed Type1", "KPI ID", each 28, Int32.Type),
		
		    #"Added Topic ID" =
		        Table.AddColumn(#"Added KPI ID", "Topic ID", each 1, Int64.Type)
		in
		    #"Added Topic ID"
