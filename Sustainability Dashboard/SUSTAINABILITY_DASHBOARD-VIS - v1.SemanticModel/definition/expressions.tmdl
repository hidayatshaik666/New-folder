expression 'CAP Projects GHG Replan History' =
		let
		    // ===== Original Replan logic =====
		    Source = #"CAP Projects Investment and Replan",
		
		    #"Removed Columns" =
		        Table.RemoveColumns(Source, {"Investment", "Value"}),
		
		    #"Insert Prev Year Column" =
		        Table.AddColumn(
		            #"Removed Columns",
		            "Prev Year",
		            each [Input Year] - 1,
		            Int64.Type
		        ),
		
		    #"Merged Prev Year" =
		        Table.NestedJoin(
		            #"Insert Prev Year Column",
		            {"Prev Year", "Year", "#", "Division", "Input Quarter"},
		            #"CAP Projects Investment and Replan - Prev Year",
		            {"Input Year", "Year", "#", "Division", "Input Quarter"},
		            "PrevYearData",
		            JoinKind.LeftOuter
		        ),
		
		    #"Expanded Prev Year" =
		        Table.ExpandTableColumn(
		            #"Merged Prev Year",
		            "PrevYearData",
		            {"Value"},
		            {"Value"}
		        ),
		
		    // ✅ Keep only Q3 baseline rows
		    #"Filter Q3 Baseline" =
		        Table.SelectRows(
		            #"Expanded Prev Year",
		            each [Input Quarter] = 3 and [Value] <> null
		        ),
		
		    #"Create Attribute Column" =
		        Table.AddColumn(
		            #"Filter Q3 Baseline",
		            "Attribute",
		            each "Replan",
		            type text
		        ),
		
		    #"Rename Columns" =
		        Table.RenameColumns(
		            #"Create Attribute Column",
		            {
		                {"#", "Project"},
		                {"Input Quarter", "Baseline Quarter"}
		            }
		        ),
		
		    #"Removed Snapshot Columns" =
		        Table.RemoveColumns(
		            #"Rename Columns",
		            {"Input Year", "Prev Year"}
		        ),
		
		    // ===== Quarter Duplication Logic START =====
		
		    // ✅ Create a Quarter reference table (1–4)
		    QuarterTable =
		        #table(
		            {"Quarter"},
		            {
		                {1},
		                {2},
		                {3},
		                {4}
		            }
		        ),
		
		    // ✅ Cross join Replan rows with all quarters
		    #"Expanded to All Quarters" =
		        Table.ExpandTableColumn(
		            Table.AddColumn(
		                #"Removed Snapshot Columns",
		                "All Quarters",
		                each QuarterTable
		            ),
		            "All Quarters",
		            {"Quarter"}
		        ),
		
		    // ===== Quarter Duplication Logic END =====
		
		    #"Changed Type" =
		        Table.TransformColumnTypes(
		            #"Expanded to All Quarters",
		            {
		                {"Quarter", Int64.Type},
		                {"Baseline Quarter", Int64.Type}
		            }
		        ),
		
		    #"Reordered Columns" =
		        Table.ReorderColumns(
		            #"Changed Type",
		            {
		                "Timestamp",
		                "Year",
		                "Quarter",
		                "Division",
		                "Project",
		                "Activity Name",
		                "Value",
		                "Attribute",
		                "Baseline Quarter"
		            }
		        ),
		
		    // ✅ Safety flag to indicate duplicated baseline
		    #"Added Replan Baseline Flag" =
		        Table.AddColumn(
		            #"Reordered Columns",
		            "Is Replan Baseline",
		            each true,
		            type logical
		        ),
		
		    #"Added KPI ID" =
		        Table.AddColumn(
		            #"Added Replan Baseline Flag",
		            "KPI ID",
		            each 28,
		            Int32.Type
		        ),
		
		    #"Added Topic ID" =
		        Table.AddColumn(
		            #"Added KPI ID",
		            "Topic ID",
		            each 1,
		            Int64.Type
		        )
		in
		    #"Added Topic ID"
		
		// let
		//     Source = #"CAP Projects Investment and Replan",
		
		//     #"Removed Columns" =
		//         Table.RemoveColumns(Source,{"Investment", "Value"}),
		
		//     #"Insert Prev Year Column" =
