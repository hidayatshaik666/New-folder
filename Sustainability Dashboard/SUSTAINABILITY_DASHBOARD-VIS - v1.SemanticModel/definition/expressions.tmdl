expression 'CAP Projects Investment and Replan' = ```
		let
		    Source = #"CAP Data",
		    #"Removed Columns" = Table.RemoveColumns(Source,{"Input Version", "Auto-generated number", "Activity Description", "Pillar", "Type of activity", /*"Activity owner",*/ "Existing in CAP", /*"Activity Status",*/ "Level of Confidence", "GHG YTD", "AEP status", "Start year", "End Year"}),
		    #"AllColumns" = Table.ColumnNames(#"Removed Columns"),
		    #"ColumnsToRemove" = 
		        List.Select(
		            #"AllColumns", 
		            each
		                not Text.Contains(_, "discount", Comparer.OrdinalIgnoreCase) and
		                not Text.Contains(_, "YTD", Comparer.OrdinalIgnoreCase)
		        ),
		    #"Result" = Table.SelectColumns(#"Removed Columns", #"ColumnsToRemove"),
		    #"RemainingColumns" = Table.ColumnNames(#"Result"),
		    #"ColumnsToAggregate" = 
		        List.Select(
		            #"RemainingColumns", 
		            each
		                Text.Contains(_, "COGS", Comparer.OrdinalIgnoreCase) or
		                Text.Contains(_, "EXPENSES", Comparer.OrdinalIgnoreCase) or
		                Text.Contains(_, "CAPEX", Comparer.OrdinalIgnoreCase) or
		                Text.Contains(_, "SWB", Comparer.OrdinalIgnoreCase)
		        ),
		    #"Aggregations" = 
		        List.Transform(
		            #"ColumnsToAggregate",
		            (col) => { col, each List.Sum(List.Transform(_, (r) => Record.Field(r, col))), type number }
		        ),
		    #"ColumnsToGroup" = {"Timestamp", "Input Year", "Input Quarter", "Division","Unit / Region","OE name", "#", "Activity Name","Activity owner","Activity Status"},
		    #"GroupedTable" = Table.Group(#"Result", #"ColumnsToGroup", #"Aggregations"),
		    
		    // Filter only columns that contain "COGS" to get each year once
		    #"COGSColumns" = List.Select(#"ColumnsToAggregate", each Text.Contains(_, "COGS")),
		    
		    // Extract each year (assuming it's the only number in the name)
		    #"Years" = List.Transform(
		        List.Select(#"ColumnsToAggregate", each Text.Contains(_, "COGS")),
		        each Text.Select(_, {"0".."9"})   // keeps only digits
		    ),
		
		    // Add new columns for each year dynamically
		    #"AddYearTotals" =
		        List.Accumulate(
		            #"Years",
		            #"GroupedTable",
		            (state, y) =>
		                Table.AddColumn(
		                    state,
		                    y,
		                    each List.Sum(
		                        List.Transform(
		                            List.Select(#"ColumnsToAggregate", (c) => Text.Contains(c, y)),
		                            (col) => Record.Field(_, col)
		                        )
		                    ),
		                    type number
		                )
		        ),
		    #"AggregatedTableColumns" = Table.ColumnNames(#"AddYearTotals"),
		    #"AggregatedColumnsToRemove" = 
		        List.Select(
		            #"AggregatedTableColumns", 
		            each
		                not Text.Contains(_, "COGS", Comparer.OrdinalIgnoreCase) and
		                not Text.Contains(_, "EXPENSES", Comparer.OrdinalIgnoreCase) and
		                not Text.Contains(_, "CAPEX", Comparer.OrdinalIgnoreCase) and
		                not Text.Contains(_, "SWB", Comparer.OrdinalIgnoreCase)
		        ),
		    #"AggregatedTable" = Table.SelectColumns(#"AddYearTotals", #"AggregatedColumnsToRemove"),
		    #"Unpivoted Only Selected Columns" = Table.Unpivot(#"AggregatedTable", #"Years", "Year", "Value"),
		    #"Changed Type" = Table.TransformColumnTypes(#"Unpivoted Only Selected Columns",{{"Year", Int64.Type}}),
		    // Only look at current and next year (to work with the Timestamp filter selection on the report)
		    #"FilterByYear" = 
		        Table.SelectRows(
		            #"Changed Type", 
		            //each [Year] = ([Input Year] + 1) or ([Year] = [Input Year])
		            each [Year] >= [Input Year]
		        ),
		    #"Added Custom" = Table.AddColumn(FilterByYear, "Investment", each if [Year] = [Input Year] then [Value] else null, type number)
		in
		    #"Added Custom"
		```
