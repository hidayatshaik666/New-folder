		    #"Unpivoted Only Selected Columns" = Table.Unpivot(#"AggregatedTable", #"Years", "Year", "Value"),
		    #"Changed Type" = Table.TransformColumnTypes(#"Unpivoted Only Selected Columns",{{"Year", Int64.Type}}),
