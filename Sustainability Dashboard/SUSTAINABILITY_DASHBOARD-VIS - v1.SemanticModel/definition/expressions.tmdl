expression 'YEE Prior Qtr' = ```
		let
		    Source = #"Sustainability List - Export",
		    #"Select Required Columns" = Table.SelectColumns(Source,{"Timestamp", "Division", "Division ID", "Topic", "Topic ID", "Data Field", "Attribute ID", "Year",  "YEE"}),   
		    #"Added End of Quarter Date Column" = Table.AddColumn(#"Select Required Columns", "End Of Quarter Date", each let
		    parts = Text.Split([Timestamp], "-Q"),
		    year = Number.FromText(parts{0}),
		    quarter = Number.FromText(parts{1}),
		    lastMonth = quarter * 3,
		    lastDay = Date.EndOfMonth(#date(year, lastMonth, 1))
		in
		    lastDay),
		    #"Changed End of Quarter to Date type" = Table.TransformColumnTypes(#"Added End of Quarter Date Column",{{"End Of Quarter Date", type date}}),
		    #"Removed Dimension Columns" = Table.RemoveColumns(#"Changed End of Quarter to Date type",{"Division", "Topic", "Data Field"}),
		    #"Filtered Rows1" = Table.SelectRows(#"Removed Dimension Columns", each ([YEE] <> null)),
		    #"Unpivoted Other Columns" = Table.UnpivotOtherColumns(#"Filtered Rows1", {"Year", "Attribute ID", "Topic ID", "Division ID", "End Of Quarter Date", "Timestamp"}, "Attribute", "Value"),
		    #"Added Custom" = Table.AddColumn(#"Unpivoted Other Columns", "TimestampNew", each (if Text.End([Timestamp],1)="4" then Number.ToText(Number.FromText(Text.Start([Timestamp],4))+1) else Text.Start([Timestamp],4)) &"-" &(if Text.End([Timestamp],1)="4" then "Q1" else "Q"& Number.ToText(Number.FromText(Text.End([Timestamp],1))+1)), type text),
		    #"Removed Columns" = Table.RemoveColumns(#"Added Custom",{"Timestamp"}),
		    #"Renamed Columns" = Table.RenameColumns(#"Removed Columns",{{"TimestampNew", "Timestamp"}})
		in
		    #"Renamed Columns"
		```
	lineageTag: 17887008-e2fa-40f3-b95e-b2e7578a40f2
	queryGroup: 'Climate Queries'

