expression 'CAP YEE Data' = ```
		let
		    Source = #"CAP Data",
		    #"Removed Columns" = Table.RemoveColumns(Source,{"Input Version", "Auto-generated number", "Activity Description", "Pillar", "Type of activity", /*"Activity owner",*/ "Existing in CAP", /*"Activity Status",*/ "Level of Confidence", "GHG YTD", "AEP status", "Start year", "End Year"}),
		    #"AllColumns" = Table.ColumnNames(#"Removed Columns"),
		    // Dynamic removal of columns not needed (columns containing certain text)
		    #"ColumnsToRemove" = 
		        List.Select(
		            #"AllColumns", 
		            each
		                Text.Contains(_, "no growth & discounted", Comparer.OrdinalIgnoreCase) or 
		                (not Text.Contains(_, "COGS", Comparer.OrdinalIgnoreCase) and 
		                not Text.Contains(_, "EXPENSES", Comparer.OrdinalIgnoreCase) and
		                not Text.Contains(_, "CAPEX", Comparer.OrdinalIgnoreCase) and
		                not Text.Contains(_, "discount", Comparer.OrdinalIgnoreCase) and
		                not Text.Contains(_, "SWB", Comparer.OrdinalIgnoreCase))
		        ),
		    #"Result" = Table.SelectColumns(#"Removed Columns", #"ColumnsToRemove"),
		    // Replace GYG (no growth & discounted) columns with just their corresponding years
		    #"RenamedColumns" = 
		        Table.TransformColumnNames(
		            Result, 
		            each let
		                ExtractNumbers = 
		                    if Text.Contains(_,"no growth & discounted") 
		                    then Text.Start(Text.Select(_, {"0".."9"}), 4) 
		                    else _
		            in
		                ExtractNumbers
		        ),
		    #"Merged Queries" = Table.NestedJoin(RenamedColumns, {"Input Year"}, MaxQuarterPerYear, {"Input Year"}, "MaxQuarterPerYear", JoinKind.LeftOuter),
		    #"Expanded MaxQuarterPerYear" = Table.ExpandTableColumn(#"Merged Queries", "MaxQuarterPerYear", {"Max Quarter"}, {"Max Quarter"})
		in
		    #"Expanded MaxQuarterPerYear"
		```
