		    #"ColumnsToAggregate" = 
		        List.Select(
		            #"RemainingColumns",
		            // Text.PositionOfAny(c, Digits) returns the position of the first digit found (or -1 if none)
		            (c) => Text.PositionOfAny(c, Digits) <> -1
		        ),
		        
		    // #"ColumnsToGroup" = 
		    //     List.Select(
		    //         #"RemainingColumns",
		    //         // Text.PositionOfAny(c, Digits) returns the position of the first digit found (or -1 if none)
		    //         (c) => Text.PositionOfAny(c, Digits) = -1
		    //     ),
		    #"ColumnsToGroup" = {"Timestamp", "Input Year", "Input Quarter", "Division", "OE name", "GHG Scope", "Max Quarter"},
		    // Build aggregation operations dynamically
		    #"Aggregations" = 
		        List.Transform(
		            #"ColumnsToAggregate",
		            // (colName) => { 
		            //     colName, 
		            //     each List.Sum(List.RemoveNulls(List.Transform(_, (r) => Record.Field(r, colName)))), 
		            //     type number 
		            // }
		            //(colName) => {colName, each List.Sum(_), type number}
		            (col) => { col, each List.Sum(List.Transform(_, (r) => Record.Field(r, col))), type number }
		        ),
		    #"GroupedTable" = Table.Group(Source, #"ColumnsToGroup", #"Aggregations"),
		    #"Unpivoted Only Selected Columns" = Table.Unpivot(GroupedTable, #"ColumnsToAggregate", "Year", "Value"),
		    #"Changed Type" = Table.TransformColumnTypes(#"Unpivoted Only Selected Columns",{{"Year", Int64.Type}}),
		    // Only look at current and next year (to work with the Timestamp filter selection on the report)
		    #"FilterByYear" = 
		        Table.SelectRows(
		            #"Changed Type", 
		            //each [Year] = ([Input Year] + 1) or ([Year] = [Input Year] and ([Max Quarter] < 4 or [Input Quarter] < 4))
		            each [Year] >= [Input Year]
		        ),
		    #"Remove Rows where Scope is 0 or null" = Table.SelectRows(#"FilterByYear", each ([GHG Scope] <> null and [GHG Scope] <> 0)),
		    #"Create Attribute ID column" = Table.AddColumn(#"Remove Rows where Scope is 0 or null", "Attribute ID", each if [GHG Scope] = 1 then 22 else if [GHG Scope] = 2 then 24 else if [GHG Scope] = 3 then 26 else null, type number),
		    #"Merged Queries" = Table.NestedJoin(#"Create Attribute ID column", {"Attribute ID"}, #"Topics and KPIs", {"KPI ID"}, "Topics and KPIs", JoinKind.LeftOuter),
		    #"Expanded Topics and KPIs" = Table.ExpandTableColumn(#"Merged Queries", "Topics and KPIs", {"Topic ID"}, {"Topic ID"}),
		    #"Division ID - Match Division to Division Table" = Table.NestedJoin(#"Expanded Topics and KPIs", {"Division"}, #"Dim Division", {"Division"}, "Division.1", JoinKind.LeftOuter),
		    #"Get Division ID" = Table.ExpandTableColumn(#"Division ID - Match Division to Division Table", "Division.1", {"Division ID"}, {"Division ID"}),
		    #"Added Attribute column" = Table.AddColumn(#"Get Division ID", "Attribute", each "YEE", type text),
		    // Look at quarters for current year
		    #"Added Standard Quarter" = Table.AddColumn(#"Added Attribute column", "Standard Quarter", each if [Year] = [Input Year] then Text.Combine({"Q", Text.From([Input Quarter], "en-GB")}) else null, type text),
		    #"Add Timestamp - KPI Trends column" = Table.DuplicateColumn(#"Added Standard Quarter", "Timestamp", "Timestamp - Copy"),
		    #"Renamed columns" = Table.RenameColumns(#"Add Timestamp - KPI Trends column",{{"Timestamp - Copy", "Timestamp - KPI Trends"}, {"OE name", "OE"}}),
		    #"Replaced Value" = Table.ReplaceValue(#"Renamed columns","YEE","YEE % of Target Delivered",Replacer.ReplaceText,{"Attribute"}),
		    #"Report Type ID - Match Attribute with Fact Table" = Table.NestedJoin(#"Replaced Value", {"Attribute"}, #"Dim Report Type", {"Report Type"}, "Report Type", JoinKind.LeftOuter),
