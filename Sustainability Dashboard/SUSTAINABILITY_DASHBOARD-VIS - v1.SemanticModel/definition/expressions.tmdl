		    //Apply the selection
		
		    FilteredTable = Table.SelectColumns(Combined, ColumnsToKeep),
		
		    //extract Year and Quarter from the column name in Period
		
		    AddYear = Table.AddColumn(FilteredTable, "Year", each 
		        let
		            // 1. Find the index (position) of the first number in the string
		            FirstDigitPos = Text.PositionOfAny([Period], {"0".."9"}),
		            // 2. Extract 4 characters starting from that position
		            YearText = if FirstDigitPos >= 0 then Text.Middle([Period], FirstDigitPos, 4) else null
		        in
		            try Number.FromText(YearText) otherwise null, 
		        Int64.Type
		    ),
		    AddQuarter = Table.AddColumn(AddYear, "Quarter", each 
		    if [Attribute] = "Actual" or [Attribute] = "Target" then "Q4"
		    else if [Attribute] = "Replan" then "Q3"
		    else if [Attribute] = "Planned Activities" then "Q4"
		    else if Text.Contains([Period],"Q1") then "Q1" 
		    else if Text.Contains([Period],"Q2") then "Q2" 
		    else if Text.Contains([Period],"Q3") then "Q3" 
		    else if Text.Contains([Period],"Q4") then "Q4" 
		    else null
		),
		
		    //build End Of Quarter Date
		    QuarterMonth = Table.AddColumn(AddQuarter, "QuarterEndMonth", each if [Quarter]="Q1" then 3 else if [Quarter]="Q2" then 6 else if [Quarter]="Q3" then 9 else if [Quarter]="Q4" then 12 else 12, Int64.Type),
		    EndOfQuarter = Table.AddColumn(QuarterMonth, "End Of Quarter Date",
		    each if [Year] <> null then Date.From(#date([Year], [QuarterEndMonth], if [QuarterEndMonth] = 3 then 31 else if [QuarterEndMonth] = 6 then 30 else if [QuarterEndMonth] = 9 then 30 else 31)) else null, type date),
		    AddTimestamp = Table.AddColumn(EndOfQuarter, "Timestamp", each if [Quarter] <> null then Text.From([Year]) & "-Q" & Text.Middle([Quarter],1,1) else if [Year] <> null then Text.From([Year]) else null, type text),
