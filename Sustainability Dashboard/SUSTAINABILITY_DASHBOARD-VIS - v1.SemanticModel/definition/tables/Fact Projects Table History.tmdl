table 'Fact Projects Table History'
	lineageTag: f0025425-2576-43cb-8eb7-31d014cf8d76

	measure Actual_All =
			
			/* Value for Actuals */
			CALCULATE(MAX('Fact Projects Table History'[Value]), 'Fact Projects Table History'[Attribute]="Actual")
		lineageTag: 65f1a770-f5f2-454f-a5f3-8618c9b2142f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Investment_All =
			
			/* Value for Investments */
			CALCULATE(MAX('Fact Projects Table History'[Value]), 'Fact Projects Table History'[Attribute]="Investment")
		lineageTag: 89ecf888-76c1-40e6-a182-4e9dd9aff6b2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Planned_All =
			
			/* Value for Planneds */
			CALCULATE(MAX('Fact Projects Table History'[Value]), 'Fact Projects Table History'[Attribute]="Planned")
		lineageTag: 811c5618-877d-4ce8-90c4-14b3cf20dfc5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Replan_All =
			
			/* Value for Replan */
			CALCULATE(MAX('Fact Projects Table History'[Value]), 'Fact Projects Table History'[Attribute]="Replan")
		lineageTag: f2e251f8-bd51-4c5f-a330-58f965ce60dc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Activity Name All' =
			
			/* Name of the project on the Top 10 Projects page */
			SELECTEDVALUE('Fact Projects Table History'[Activity Name])
		lineageTag: dd152556-4318-4d87-94fe-4ed6d1525f92

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Region with Max Planned' = ```
			
			VAR SelectedTimestamp = SELECTEDVALUE('Fact Projects Table History'[Timestamp])
			VAR SelectedYear = LEFT(SelectedTimestamp, 4)
			VAR SelectedQuarter = RIGHT(SelectedTimestamp, 2)
			VAR PriorYearTimestamp = (VALUE(SelectedYear) - 1) & "-" & SelectedQuarter
			VAR FilteredTable = 
			    FILTER(
			        'Fact Projects Table History',
			        'Fact Projects Table History'[Timestamp] = PriorYearTimestamp &&
			        'Fact Projects Table History'[Attribute] = "Planned"
			    )
			VAR MaxValue = MAXX(FilteredTable, 'Fact Projects Table History'[Value])
			VAR TopRegion = 
			    MAXX(
			        FILTER(FilteredTable, 'Fact Projects Table History'[Value] = MaxValue),
			        'Fact Projects Table History'[Unit / Region]
			    )
			RETURN "Region : " & TopRegion
			```
		lineageTag: e9632c5d-9c2d-4608-93a7-48c301cab8be

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Planned Rank' =
			
			VAR PlannedValue = [Planned_All]
			RETURN
			IF (
			    NOT ISBLANK ( PlannedValue ),
			    RANKX (
			        ALLSELECTED ( 'Projects With Actuals'[Project Name] ),
			        CALCULATE ( [Planned_All] ),
			        ,
			        DESC,
			        DENSE
			    )
			)
		lineageTag: 21925691-a5b0-470d-840d-2bcab118a76a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Show in Top 10 (Planned)' =
			
			IF ( [Planned Rank] <= 10, 1 )
		lineageTag: 88f235fc-2481-4a57-a768-432f032fb3e1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Has Any Value' =
			
			IF (
			    NOT ISBLANK ( [Actual_All] )
			        || NOT ISBLANK ( [Planned_All] )
			        || NOT ISBLANK ( [Investment_All] )
			        || NOT ISBLANK ( [Replan_Fixed_Q3] ),
			    1,
			    0
			)
		lineageTag: 478bf75d-ca8e-42f8-b818-669636efe043

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Planned (Aligned)' =
			
			VAR HasActual =
			    CALCULATE (
			        COUNTROWS ( 'Fact Projects Table History' ),
			        'Fact Projects Table History'[Attribute] = "Actual"
			    )
			RETURN
			IF (
			    HasActual > 0,
			    CALCULATE (
			        SUM ( 'Fact Projects Table History'[Value] ),
			        'Fact Projects Table History'[Attribute] = "Planned"
			    ),
			    BLANK ()
			)
		lineageTag: c77d69f9-a296-423f-8b55-afbb6540f2a8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Max Planned Region' = ```
			
			VAR MaxValue = 
			    CALCULATE(
			        MAX('Fact Projects Table History'[Value]), 
			        'Fact Projects Table History'[Attribute] = "Planned"
			    )
			RETURN
			    CALCULATE(
			        FIRSTNONBLANK('Fact Projects Table History'[Unit / Region], 1),
			        'Fact Projects Table History'[Attribute] = "Planned",
			        'Fact Projects Table History'[Value] = MaxValue
			    )
			```
		lineageTag: 97510eec-83c6-498c-b168-b7107c1ab294

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Measure
		lineageTag: a8f06b96-0c99-4c92-a6fa-a7083554d7f5

		annotation 43dbc3e8-3a1c-4b6f-9923-b49ff7d6691c = True

	measure Replan_Fixed_Q3 = ```
			
			CALCULATE(
			    [Replan_All], 
			    -- This forces Power BI to use the Inactive relationship we just created
			    USERELATIONSHIP('Fact Projects Table History'[Year], 'Replan_Bridge'[TargetYear]),
			    USERELATIONSHIP('Fact Projects Table History'[Quarter], 'Replan_Bridge'[TargetQuarter]),
			    -- This keeps the slicer from filtering our "Hardcoded" 2025-Q3 logic
			    REMOVEFILTERS('Fact Projects Table History'[Year], 'Fact Projects Table History'[Quarter])
			)
			// VAR _AllProjects = 
			//     CALCULATETABLE(
			//         VALUES('Fact Projects Table History'[Project Name]),
			//         ALL('Fact Projects Table History'), -- Remove all filters from the table
			//         'Fact Projects Table History'[Attribute] = "Replan",
			//         'Fact Projects Table History'[Year] = 2025,
			//         'Fact Projects Table History'[Quarter] = 3
			//     )
			
			// RETURN
			// CALCULATE(
			//     [Replan_All],
			//     REMOVEFILTERS('Fact Projects Table History'), -- Clear slicers
			//     KEEPFILTERS(_AllProjects), -- Only keep projects from our "Golden Set"
			//     'Fact Projects Table History'[Year] = 2025,
			//     'Fact Projects Table History'[Quarter] = 3
			// )
			```
		lineageTag: 7f5f78c7-1265-4ad0-8e18-2603f4f27198

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Replan_Test =
			
			CALCULATE (
			    MAX ( 'Fact Projects Table History'[Value] ),
			    'Fact Projects Table History'[Attribute] = "Replan",
			    REMOVEFILTERS ( 'Period Table'[Quarter] ),
			    'Period Table'[Quarter] = 3
			)
		lineageTag: 7c74541a-d094-46d7-b9d1-8e67e89603e2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

