	column Key =
			
			VAR DivVal = COALESCE('Fact Projects Table History'[Division], "NA")
			VAR ProjVal = COALESCE('Fact Projects Table History'[Project], "NA")
			VAR ActVal  = COALESCE('Fact Projects Table History'[Activity Name], "NA")
			RETURN
			DivVal & "-" & ProjVal & "-" & ActVal
