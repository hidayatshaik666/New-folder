		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YEE% of Target Delivered' = ```
			
			    /* Measure for calculating YEE% of Target for the scorecard page. Calculates current target and YEE from the KPI Dynamic measure for the given filter selections and returns current YEE divided by target */
			
			    VAR ReportType = SELECTEDVALUE('Dim Report Type'[Report Type])
			    VAR KPIName = SELECTEDVALUE('Dim KPI'[KPI Name])
			    VAR __SingleKPICheck = HASONEVALUE('Dim KPI'[KPI Name])
			    VAR SelectedYear = VALUES('Fact Table'[Year])
			    VAR ReportingPeriod = VALUES('Fact Table'[Timestamp])
			    VAR Division_ID = VALUES('Dim Division'[Division ID])
			    
			    VAR _stdQuarter = SELECTEDVALUE('Fact Table'[Standard Quarter])
			    VAR CurrentTarget = CALCULATE(
			        CALCULATE(
			            [KPI Dynamic Measure],
			            'KPI Intelligence'[Time Period Calculations] = "Current Quarter"
			        ),
			        ALLEXCEPT(
			            'Fact Table',
			            'Dim Division'[Division],
			            'Fact Table'[Year],
			            'Fact Table'[Standard Quarter],
			            'Fact Table'[Timestamp]
			        ),
			        'Dim Report Type'[Report Type] = "Targets",
			        'Fact Table'[Standard Quarter] = _stdQuarter,
			        'Fact Table'[Year] = SelectedYear
			    )
			    VAR CurrentYEE =
			    CALCULATE(
			        CALCULATE(
			            [KPI Dynamic Measure],
			            'KPI Intelligence'[Time Period Calculations] = "Current Quarter"
			        ),
			        ALLEXCEPT(
			            'Fact Table',
			            'Dim Division'[Division],
			            'Fact Table'[Timestamp]
			        ),
			        'Dim Report Type'[Report Type] = "YEE",
			        'Fact Table'[Standard Quarter] = _stdQuarter,
			        'Fact Table'[Year] = SelectedYear
			    )
			
			    RETURN
			        IF(
			            ISBLANK(CurrentTarget),
			            BLANK(),
			            CurrentYEE / CurrentTarget
			        )
			```
		displayFolder: KPI Dynamic Measure
		lineageTag: c739d82f-07f4-4f85-9dd9-2004c92194be

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure NoCalcList = ```
			
			/* List of KPIs where YEE% of Target delivered and YTD Active Projects are not applicable */
			    VAR KPIName = SELECTEDVALUE('Dim KPI'[KPI Name])
			
			    RETURN
			        IF(
			            KPIName in {
			                "GHG change vs 2015", 
			                "GHG intensity by (ton of purchased material)", 
			                "GHG intensity by ($M revenue)", 
			                "GHG intensity change vs 2015 (ton of purchased material)", 
			                "Waste intensity (kg per pet visit)"
			            }, 
			            TRUE(), 
			            FALSE()
			        )
			```
		lineageTag: 33097381-a5c8-4e28-8f53-bb875689f81e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Finance Costs - Replan vs Current YEE' = ```
			
			
			/* Difference between Replan and Current YEE on the Investment Summary Costs Chart (value shown in bubble at the bottom) */
			
			VAR Replan = 
			    CALCULATE(
			        SUM('Fact Finance Table'[Value]),
			        'Fact Finance Table'[Attribute] = "Current Year Replan",
			        'Fact Finance Table'[KPI] IN {"COGS", "CAPEX", "OHS"}
			    )
			
			VAR Current_YEE = 
			    CALCULATE(
			        SUM('Fact Finance Table'[Value]),
			        'Fact Finance Table'[Attribute] = "YEE Current quarter",
			        'Fact Finance Table'[KPI] IN {"COGS", "CAPEX", "OHS"}
			    )
			
			Return Current_YEE - Replan
			```
		formatString: 0
		lineageTag: 28100376-3a4f-4834-9f91-bb5f985ab48d

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Finance Sust Pillar - Replan vs Current YEE' = ```
			
			/* Difference between Replan and Current YEE on the Investment Summary Sustainability Pillar Chart (value shown in bubble at the bottom) */
			VAR Replan = 
			    CALCULATE(
			        SUM('Fact Finance Table'[Value]),
			        'Fact Finance Table'[Attribute] = "Current Year Replan",
			        'Fact Finance Table'[KPI] IN {"Circularity", "Enablers", "Climate & Sourcing", "Thriving People"}
			    )
			
			VAR Current_YEE = 
			    CALCULATE(
			        SUM('Fact Finance Table'[Value]),
			        'Fact Finance Table'[Attribute] = "YEE Current quarter",
			        'Fact Finance Table'[KPI] IN {"Circularity", "Enablers", "Climate & Sourcing", "Thriving People"}
			    )
			
			Return DIVIDE((Current_YEE - Replan), Replan, 0)
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: c710075e-c147-4b85-8c6a-0bc38ca491b2

	measure 'Finance Cost Chart Title' = ```
			
			/* Title of the Cost chart on the Investment Summary page, showing dynamic division selection */
			
			    Var Initial_Title = "INVESTMENTS ($M) PER COST TYPE - "
			
			    VAR SelectedDivisions = COUNTROWS(VALUES('Fact Finance Table'[Division]))
			    VAR AllDivisions = COUNTROWS(ALLNOBLANKROW('Fact Finance Table'[Division]))
			    VAR Divisions_List = 
			        IF(
			            SelectedDivisions >= AllDivisions,
			            "All of Petcare",
			            CONCATENATEX(
			                VALUES('Fact Finance Table'[Division]),
			                IF([Division] = "Pet Nutrition", "PN", IF([Division] = "Royal Canin", "RC", [Division])),
			                ", "
			            )
			        )
			
			    RETURN
			        Initial_Title & UPPER(Divisions_List)
			        
			```
		lineageTag: 8017eec3-e54b-42c6-babc-84252c59ab4b

