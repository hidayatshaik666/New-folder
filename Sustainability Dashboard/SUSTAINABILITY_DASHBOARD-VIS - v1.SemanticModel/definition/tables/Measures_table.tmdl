	measure 'KPI Dynamic Measure' = ```
			
			/* KPI Dynamic measure for the scorecard page, retreiving calculations for each KPI on the page for the selected time period, year and division */
			
			VAR __SingleKPICheck = HASONEVALUE('Dim KPI'[KPI Name]) -- Checks that only one KPI is being evaluated at a visual level
			VAR __KPIName = SELECTEDVALUE('Dim KPI'[KPI Name]) -- Returns the name of the KPI that is being evaluated from the KPI Dimension table
			VAR ReportType = SELECTEDVALUE('Dim Report Type'[Report Type])
			VAR _ErrorString = "KPI Mapping Error: The KPI " & __KPIName & " can not be calculated due to an unmapped SWITCH function"
			
			RETURN
			    SWITCH(
			            TRUE(),
			            -- For every KPI, confrim that only one KPI is being evaluated, and return the Base Measure for that KPI Calculation
			           __SingleKPICheck
			            = TRUE ()
			            && __KPIName = "Advocate", [Advocate], 
			            __SingleKPICheck
			            = TRUE ()
			            && __KPIName = "Circular", [Circular], 
			            __SingleKPICheck
			            = TRUE ()
			            && __KPIName = "Absolute GHG emissions (total actual GHG footprint)", [Absolute GHG emmisions (total actual GHG footprint)], 
			            __SingleKPICheck
			            = TRUE() 
			            && __KPIName = "Annual GHG reduction through carbon credits", [Annual GHG reduction through carbon credits],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Finished goods tonnage", [Finished goods tonnage],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "T1 suppliers with valid EcoVadis rating", [T1 suppliers with valid EcoVadis rating],   
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Cumulative people reached with TP programs (since 2015)", [Cumulative people reached with TP programs (since 2015)],               
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "D4C score", [D4C Score],            
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Total targeted T1 suppliers", [Total targeted T1 suppliers],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Eliminate", [Eliminate],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Extreme and High-Risk Own Operations Sites", [Extreme and High-Risk Own Operations Sites],
			             __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Extreme and High-Risk Tier 1 Supplier Sites", [Extreme and High-Risk Tier 1 Supplier Sites],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Extreme and High-Risk Own Operations Sites Actioned", [Extreme and High-Risk Own Operations Sites Actioned],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Extreme and High-Risk Tier 1 Supplier Sites Actioned", [Extreme and High-Risk Own Operations Sites Actioned],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Tons of Specialty Recycling Diverted", [Tons of Specialty Recycling Diverted],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Tons of Waste Diverted through Prevention Programs", [Tons of Waste Diverted through Prevention Programs],            
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Pet Visits", [Pet Visits],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "RAcc Program", [RAcc Program],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Raw materials tonnage", [Raw materials tonnage],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Recycled content volume", [Recycled content volume],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Recycled plastic volume", [Recycled plastic volume],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Revenue", [Revenue],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Scope 1 Annual GHG reduction through activity set", [Scope 1 Annual GHG reduction through activity set],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Scope 1 cumulative GHG reduction through activity set", [Scope 1 cumulative GHG reduction through activity set],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Scope 2 Annual GHG reduction through activity set", [Scope 2 Annual GHG reduction through activity set],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Scope 2 cumulative GHG reduction through activity set", [Scope 2 cumulative GHG reduction through activity set],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Scope 3 Annual GHG reduction through activity set", [Scope 3 Annual GHG reduction through activity set],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Scope 3 cumulative GHG reduction through activity set", [Scope 3 cumulative GHG reduction through activity set],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Total Annual GHG reduction through activity set", [Total Annual GHG reduction through activity set],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Total cumulative GHG reduction through activity set", [Total cumulative GHG reduction through activity set],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Total non-medical waste", [Total non-medical waste],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Total plastic volume (virgin + recycled)", [Total plastic volume (virgin + recycled)],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Volume of packaging classified as D4C", [Volume of packaging classified as D4C],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Volume of packaging classified as NOT D4C", [Volume of packaging classified as NOT D4C],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "GHG change vs 2015", [GHG change vs 2015],
			              __SingleKPICheck
			            = TRUE()
			            && __KPIName = "GHG intensity by (ton of purchased material)", [GHG intensity by (ton of purchased material)],
			             __SingleKPICheck
			            = TRUE()
			            && __KPIName = "GHG intensity by ($M revenue)", [GHG intensity by ($M revenue)],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "GHG intensity change vs 2015 (ton of purchased material)", [GHG Intensity Change vs 2015 (tone of purchased material)],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "% D4C", [% D4C],
			             __SingleKPICheck
			            = TRUE()
			            && __KPIName = "% Circular", [% Circular],
			              __SingleKPICheck
			            = TRUE()
			            && __KPIName = "% Advocate", [% Advocate],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "% Eliminate", [% Eliminate],
			              __SingleKPICheck
			            = TRUE()
			            && __KPIName = "% virgin plastic change vs 2019", [% virgin plastic change vs 2019],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "% recycled content", [% recycled content],
			            __SingleKPICheck
			            = TRUE()
			            && __KPIName = "Waste intensity (kg per pet visit)", [Waste intensity (kg per pet visit)],
			           __SingleKPICheck = BLANK(), BLANK(),
			 -- If KPI can not be found, then an error is return to the user
			            ERROR ("KPI Mapping Error: The KPI can not be calculated due to an unmapped SWITCH function")
			    )
			
			```
		displayFolder: KPI Dynamic Measure
		lineageTag: 1171274a-5be2-47ae-aaa9-9cb44486e22c

