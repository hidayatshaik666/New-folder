		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'RAG Color – Current Quarter' = ```
			
			/* Color coding for the scorecard */
			    VAR ReportType = SELECTEDVALUE('Dim Report Type'[Report Type])
			    VAR PercCurrentYEEValue  = CALCULATE([Current Quarter], 'Dim Report Type'[Report Type] = "YEE % of Target Delivered")
			    VAR CurrentYEEValue  = CALCULATE([Current Quarter], 'Dim Report Type'[Report Type] = "YEE")
			
			    VAR KPIName = SELECTEDVALUE('Dim KPI'[KPI Name])
			    // VAR __SingleKPICheck = HASONEVALUE('Dim KPI'[KPI Name])
			    VAR SelectedYear = VALUES('Fact Table'[Year])
			    VAR ReportingPeriod = VALUES('Fact Table'[Timestamp])
			    VAR Division = VALUES('Dim Division'[Division ID])
			    VAR _stdQuarter = SELECTEDVALUE('Fact Table'[Standard Quarter])
			    VAR CurrentTarget = CALCULATE(
			        CALCULATE(
			            [KPI Dynamic Measure],
			            'KPI Intelligence'[Time Period Calculations] = "Current Quarter"
			        ),
			        ALLEXCEPT(
			            'Fact Table',
			            'Dim Division'[Division],
			            'Fact Table'[Year],
			            'Fact Table'[Standard Quarter],
			            'Fact Table'[Timestamp]
			        ),
			        'Dim Report Type'[Report Type] = "Targets",
			        'Fact Table'[Standard Quarter] = _stdQuarter,
			        'Fact Table'[Year] = SelectedYear
			    )
			    
			    VAR HigherIsBetter = SELECTEDVALUE('Dim KPI'[Higher is Better])
			    
			    RETURN
			        IF(
			            (SelectedYear <> CONVERT(LEFT(ReportingPeriod, 4), INTEGER)) || (_stdQuarter <> RIGHT(ReportingPeriod, 2)),
			            BLANK(),
			            IF(
			                ISBLANK(PercCurrentYEEValue),
			                IF(
			                    ISBLANK(CurrentYEEValue),
			                    4,
			                    IF(CONTAINSSTRING(KPIName, "%"), 
			                        SWITCH (
			                            TRUE(),
			                            HigherIsBetter = "Y" && ReportType="YEE" && CurrentYEEValue >= 0.90 ,  1, //"#BFE898",   // green
			                            HigherIsBetter = "Y" && ReportType="YEE" && CurrentYEEValue >= 0.75 ,  2, //"#00AF66",   // amber
			                            HigherIsBetter = "Y" && ReportType="YEE" && CurrentYEEValue < 0.75 ,  3, //"#FF1414",   // red
			                            HigherIsBetter = "N" && ReportType="YEE" && CurrentYEEValue >= 0.90 ,  3, //"#FF1414"   // red
			                            HigherIsBetter = "N" && ReportType="YEE" && CurrentYEEValue >= 0.75 ,  2, //"#00AF66",   // amber
			                            HigherIsBetter = "N" && ReportType="YEE" && CurrentYEEValue < 0.75 ,  1 //"#BFE898",   // green
			                        ),
			                        SWITCH (
			                            TRUE(),
			                            HigherIsBetter = "Y" && ReportType="YEE" && CurrentYEEValue >= CurrentTarget ,  1, //"#00AF66",   // green
			                            HigherIsBetter = "N" && ReportType="YEE" && CurrentYEEValue <= CurrentTarget ,  1, //"#00AF66",   // green
			                            HigherIsBetter = "Y" && ReportType="YEE" && CurrentYEEValue < CurrentTarget ,  3, //"#BFE898",   // red
			                            HigherIsBetter = "N" && ReportType="YEE" && CurrentYEEValue > CurrentTarget ,  3 //"#BFE898"   // red
			                        )
			                    )
			                ),
			                SWITCH (
			                    TRUE(),        
			                    HigherIsBetter = "Y" && ReportType IN {"YEE", "YEE % of Target Delivered"}  && PercCurrentYEEValue >= 0.90,  1, //"#00AF66",   // green
			                    HigherIsBetter = "Y" && ReportType IN {"YEE", "YEE % of Target Delivered"}  && PercCurrentYEEValue >= 0.75, 2, //  "#F5CD47",   // amber
			                    HigherIsBetter = "Y" && ReportType IN {"YEE", "YEE % of Target Delivered"} && PercCurrentYEEValue < 0.75,  3, //  "#FF1414",   // red
			                    HigherIsBetter = "N" && ReportType IN {"YEE", "YEE % of Target Delivered"}  && PercCurrentYEEValue >= 0.90, 3, // "#FF1414" ,   // red
			                    HigherIsBetter = "N" && ReportType IN {"YEE", "YEE % of Target Delivered"}  && PercCurrentYEEValue >= 0.75, 2, // "#F5CD47",   // amber
			                    HigherIsBetter = "N" && ReportType IN {"YEE", "YEE % of Target Delivered"}  && PercCurrentYEEValue < 0.75,  1, // "#00AF66",   // green
			                    4 //"#FFFFFF")
			                )
			            )
			        )
			```
		lineageTag: aedf6f5e-1ebe-4371-b58b-8ae96b0dd89a

