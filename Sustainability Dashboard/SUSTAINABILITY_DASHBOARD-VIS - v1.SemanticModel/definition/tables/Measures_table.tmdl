	measure 'Current Quarter' = ```
			
			/*Scorecard Current Values obtained from the KPI Dynamic Measure. YEE% of Target Delivered is calculated separately as this is derived from two other KPIs (YEE and Targets) */ 
			VAR KPIName = SELECTEDVALUE('Dim KPI'[KPI Name])
			VAR ReportType = SELECTEDVALUE('Dim Report Type'[Report Type])
			VAR KPI_Value = 
			    CALCULATE(
			        [KPI Dynamic Measure], 
			        'KPI Intelligence'[Time Period Calculations] = "Current Quarter"
			    )
			
			VAR YEE_Percent = 
			    CALCULATE(
			        [YEE% of Target Delivered], 
			        'KPI Intelligence'[Time Period Calculations] = "Current Quarter"
			    )
			
			RETURN
			    SWITCH(
			        ReportType,
			        "YEE % of Target Delivered",
			            //BLANK(),
			            IF(
			                OR(CONTAINSSTRING(KPIName, "%"), [NoCalcList]), 
			                //CONTAINSSTRING(KPIName, "%"), 
			                BLANK(),
			                YEE_Percent
			            ),
			        "YTD Active Projects",
			            IF(
			                OR(CONTAINSSTRING(KPIName, "%"), [NoCalcList]),
			                BLANK(),
			                KPI_Value
			            ),
			        "Targets",
			            IF(
			                //OR(CONTAINSSTRING(KPIName, "%"), [NoCalcList]),
			                CONTAINSSTRING(KPIName, "%"),
			                BLANK(),
			                KPI_Value
			            ),
			        KPI_Value
			    )
			```
		lineageTag: b27507f0-0077-4448-ba1f-1a0400b02a72

		formatStringDefinition = ```
				VAR FormatString = SELECTEDVALUE('Dim KPI'[Data Format])
				VAR CurrentValue = ABS(IF(SELECTEDMEASURE()= "-", BLANK(), SELECTEDMEASURE()))
				VAR ReportType = SELECTEDVALUE('Dim Report Type'[Report Type])
				VAR KPIName = SELECTEDVALUE('Dim KPI'[KPI Name])
				RETURN
				
				
				IF(ReportType IN {"Replan", "Investment YEE"}, 
				SWITCH (
				        TRUE (),
				        // Special cases to force K and M in the sample report
				        CurrentValue <= 1E3, "$#,0.0",
				        CurrentValue <= 1E6, "$#,0,.0 K",
				        CurrentValue <= 1E9, "$#,0,,.0 M",
				        CurrentValue <= 1E12, "$#,0,,,.0 B"
				    ),
				
				//IF(ReportType = "YEE % of Target Delivered" && CONTAINSSTRING(KPIName, "%"), BLANK(),
				IF(ReportType = "YEE % of Target Delivered", "#,0.0%",
				
				IF(ReportType IN {"YTD Active Projects", "Total Planned Activities"},
				SWITCH (
				        TRUE (),
				        // Special cases to force K and M in the sample report
				        CurrentValue <= 1E3, "#,0",
				        CurrentValue <= 1E6, "#,0, K",
				        CurrentValue <= 1E9, "#,0,, M",
				        CurrentValue <= 1E12, "#,0,,, B"
				    ),
				
				IF(CONTAINSSTRING(FormatString, "%"), FormatString
				,
				
				IF(CONTAINSSTRING(FormatString, "$"),
				    SWITCH (
				        TRUE (),
				        // Special cases to force K and M in the sample report
				        CurrentValue <= 1E3, "$#,0.0",
				        CurrentValue <= 1E6, "$#,0,.0 K",
				        CurrentValue <= 1E9, "$#,0,,.0 M",
				        CurrentValue <= 1E12, "$#,0,,,.0 B"
				    ),
				
				IF(CONTAINSSTRING(FormatString, " kt"),
				    SWITCH (
				        TRUE (),
				        // Special cases to force K and M in the sample report
				        CurrentValue <= 1E3, "#,0.0 kt",
				        CurrentValue <= 1E6, "#,0,.0 K kt",
				        CurrentValue <= 1E9, "#,0,,.0 M kt",
				        CurrentValue <= 1E12, "#,0,,,.0 B kt"
				    ),
				
				    SWITCH (
				        TRUE (),
				        // Special cases to force K and M in the sample report
				       CurrentValue <= 1E3, "#,0; -#,0" ,
				       CurrentValue<= 1E6, "#,0,.0 K;,-#,0,.0 K",
				       CurrentValue <= 1E9, "#,0,,.0 M; -#,0,,.0 M",
				       CurrentValue <= 1E12, "#,0,,,.#0 B; -#,0,,,.#0 B"
				    )))))))
				```

	measure 'Timestamp title' = ```
			
			/* Title for the matrix on the Scorecard page */
			    VAR SelectedDivisions = COUNTROWS(VALUES('Dim Division'[Division]))
			    VAR AllDivisions = COUNTROWS(ALLNOBLANKROW('Dim Division'[Division]))
			    VAR Divisions_List = 
			        IF(
			            SelectedDivisions >= AllDivisions,
			            "All of Petcare",
			            CONCATENATEX(
			                VALUES('Dim Division'[Division]),
			                'Dim Division'[Division],
			                ", "
			            )
			        )
			
			    RETURN
			        "Reporting Period: " & 
			        " " &
			        SELECTEDVALUE('Fact Table'[Timestamp]) & 
			        " for " & 
			        Divisions_List
			
			```
		lineageTag: fc3881fb-bfec-468e-b2f9-23269515dd02

